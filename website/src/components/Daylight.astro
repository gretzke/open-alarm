---
import PhoneFrame from './PhoneFrame.astro';
---
<section id="s-daylight" class="feature on-dawn">
  <div class="container split">
    <div>
      <span class="eyebrow"><span class="time">13:30</span> Later that day</span>
      <h2 class="h2">Gentler by daylight.</h2>
      <p class="lead">Once you're up, OpenAlarm relaxes. The rest of the app is quick, quiet scheduling.</p>
      <div class="tile-grid">
        <div class="tile"><h3>Naps</h3><p>Countdown alarms with pause, resume, and extend — controlled from the Lock Screen and Dynamic Island.</p></div>
        <div class="tile"><h3>Skip once</h3><p>Skip or move a single occurrence of a repeating alarm. The schedule restores itself afterwards.</p></div>
        <div class="tile"><h3>Settings cascade</h3><p>Global defaults, separate nap defaults, and per-alarm overrides — set it once, tweak where needed.</p></div>
        <div class="tile"><h3>Open source</h3><p>The whole app is on GitHub, including the scheduling core and its test suite.</p></div>
      </div>
    </div>
    <div>
      <PhoneFrame simNote="simulated · real screenshot goes here">
        <div class="sim-nap">
          <div class="label">Nap</div>
          <div class="cd">22:47</div>
          <div class="controls"><span class="pill">Pause</span><span class="pill">+5 min</span></div>
        </div>
      </PhoneFrame>
    </div>
  </div>
</section>

<style>
  .tile-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); gap: 14px; margin-top: 34px; }
  .tile { padding: 20px; border-radius: var(--r-card); background: rgba(255,255,255,0.35); border: 1px solid rgba(32,16,5,0.15); backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px); }
  .tile h3 { font-weight: 900; font-size: 1.15rem; margin-bottom: 6px; }
  .tile p { font-size: 0.9375rem; line-height: 1.55; color: rgba(32,16,5,0.8); }
  .sim-nap { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; background: #000; color: var(--ink); }
  .sim-nap .label { font-size: 0.8rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-2); }
  .sim-nap .cd { font-weight: 900; font-size: 3rem; font-variant-numeric: tabular-nums; line-height: 1; }
  .sim-nap .controls { display: flex; gap: 10px; margin-top: 10px; }
  .sim-nap .pill { padding: 9px 18px; border-radius: 16px; font-weight: 800; font-size: 0.85rem; background: var(--glass-fill); border: 1px solid var(--glass-stroke); }
</style>
