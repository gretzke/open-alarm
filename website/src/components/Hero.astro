---
import PhoneFrame from './PhoneFrame.astro';
---
<header class="hero on-night container">
  <span class="eyebrow"><span class="time">05:58</span> Still dark</span>
  <h1 class="display">The alarm that makes sure you're actually up.</h1>
  <p class="sub">Disarm challenges you can't sleep through, a wake-up check that catches you dozing off again, and a snooze budget that runs out. Open source, built on AlarmKit for iOS&nbsp;26.</p>
  <div class="cta-row">
    <a class="appstore" href="#" data-appstore-todo aria-label="Download on the App Store">
      <img class="badge-img" src="/badges/app-store-badge.svg" alt="Download on the App Store" width="200" height="56" />
    </a>
    <a class="btn" href="https://github.com/gretzke/open-alarm">View on GitHub</a>
  </div>
  <div class="phone-wrap">
    <PhoneFrame island={false}>
      <img class="app-shot" src="/screenshots/alarm-list.png" alt="OpenAlarm showing weekday and weekend alarms" />
    </PhoneFrame>
  </div>
</header>

<style>
  .hero { min-height: 100svh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 96px 0 0; }
  .hero h1 { font-size: clamp(2.6rem, 6.5vw, 5rem); max-width: 17ch; }
  .hero .sub { max-width: 54ch; margin: 22px auto 34px; color: var(--ink-2); font-size: 1.1875rem; }
  .hero .phone-wrap { margin-top: 60px; margin-bottom: -18vh; }

  .app-shot { width: 100%; height: 100%; object-fit: cover; display: block; }
</style>
