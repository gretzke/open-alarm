---
import PhoneFrame from './PhoneFrame.astro';
---
<section id="s-wakeupcheck" class="feature on-night">
  <div class="container split">
    <div>
      <span class="eyebrow"><span class="time">06:07</span> The wake-up check</span>
      <h2 class="h2">Still awake?</h2>
      <p class="lead">The most dangerous moment of the morning is the one right after the alarm stops. A few minutes later, OpenAlarm checks back. No answer — the whole thing starts again.</p>
    </div>
    <div>
      <PhoneFrame simNote="simulated · real screenshot goes here">
        <div class="sim-check">
          <div class="q">Are you awake?</div>
          <div class="cd">0:42</div>
          <div class="cta">I'm up</div>
          <div class="warn">No confirmation → the alarm fires again</div>
        </div>
      </PhoneFrame>
    </div>
  </div>
</section>

<style>
  .sim-check { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10px; padding: 24px 18px; text-align: center; color: var(--ink-dark); background: linear-gradient(to bottom, #ffd84d, #fff3cf); }
  .sim-check .q { font-weight: 900; font-size: 1.45rem; }
  .sim-check .cd { font-weight: 900; font-size: 2.4rem; font-variant-numeric: tabular-nums; }
  .sim-check .cta { margin-top: 12px; width: 80%; padding: 11px 0; border-radius: 16px; font-weight: 800; font-size: 0.95rem; background: var(--ink-dark); color: #fff; }
  .sim-check .warn { font-size: 0.7rem; color: rgba(32,16,5,0.7); }
</style>
