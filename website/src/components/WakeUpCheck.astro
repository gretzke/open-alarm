---
import PhoneFrame from './PhoneFrame.astro';
---
<section id="s-wakeupcheck" class="feature on-night">
  <div class="container split">
    <div>
      <span class="eyebrow"><span class="time">06:04</span> The wake-up check</span>
      <h2 class="h2">Still awake?</h2>
      <p class="lead">The most dangerous moment of the morning is the one right after the alarm stops. A few minutes later, OpenAlarm checks back. No answer — the whole thing starts again.</p>
    </div>
    <div>
      <PhoneFrame island={false}>
        <img class="app-shot" src="/screenshots/wake-up-check.png" alt="OpenAlarm wake-up check asking for confirmation at 06:04" loading="lazy" />
      </PhoneFrame>
    </div>
  </div>
</section>

<style>
  .app-shot { width: 100%; height: 100%; object-fit: cover; display: block; }
</style>
