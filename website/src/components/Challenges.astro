---
import PhoneFrame from './PhoneFrame.astro';
---
<section id="s-challenges" class="feature on-night">
  <div class="container">
    <div class="split intro-split">
      <div>
        <span class="eyebrow"><span class="time">06:01</span> Earn the silence</span>
        <h2 class="h2">Silence is earned.</h2>
        <p class="lead">Stopping the alarm means finishing a challenge — with your brain, your legs, or both. The sun keeps rising while you work on it.</p>
      </div>
      <div>
        <PhoneFrame simNote="simulated · real screenshot goes here">
          <div class="sim-math">
            <div class="progress">Problem 1 of 3</div>
            <div class="expr">17 + 24</div>
            <div class="answer">4</div>
            <div class="keypad">
              {['1','2','3','4','5','6','7','8','9','⌫','0','Go'].map((k) => <span class="key">{k}</span>)}
            </div>
          </div>
        </PhoneFrame>
      </div>
    </div>
    <div class="challenge-grid">
      <div class="challenge">
        <svg class="icon" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M8 14h12M14 8v12M24 12h12M24 30h12M24 36h12M8 26l12 12M20 26L8 38"/></svg>
        <h3>Math</h3><p>Chained problems you have to type out. Wrong answer? Try again.</p>
        <div class="levels">Easy → Nightmare</div>
      </div>
      <div class="challenge">
        <svg class="icon" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"><rect x="6" y="6" width="12" height="12" rx="3" fill="currentColor" stroke="none" opacity=".9"/><rect x="26" y="6" width="12" height="12" rx="3"/><rect x="6" y="26" width="12" height="12" rx="3"/><rect x="26" y="26" width="12" height="12" rx="3" fill="currentColor" stroke="none" opacity=".9"/></svg>
        <h3>Memory</h3><p>Memorize the squares, then tap them back. No autopilot.</p>
        <div class="levels">Gentle → Photographic</div>
      </div>
      <div class="challenge">
        <svg class="icon" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M14 38c-2-6-3-12 1-16s10-3 11 2-2 8-6 8-6-2-6-6M30 6c2 5 3 10-1 13"/><circle cx="31" cy="27" r="3" fill="currentColor" stroke="none"/></svg>
        <h3>Steps</h3><p>Walk it off. The pedometer counts — it stops when you hit your goal.</p>
        <div class="levels">You pick the step goal</div>
      </div>
      <div class="challenge">
        <svg class="icon" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><rect x="15" y="8" width="14" height="28" rx="4"/><path d="M8 14l-3 8 3 8M36 14l3 8-3 8"/></svg>
        <h3>Shake</h3><p>Shake the phone until the meter fills. Half-hearted doesn't count.</p>
        <div class="levels">Gentle → Earthquake</div>
      </div>
      <div class="challenge">
        <svg class="icon" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M6 14v-4a4 4 0 014-4h4M30 6h4a4 4 0 014 4v4M38 30v4a4 4 0 01-4 4h-4M14 38h-4a4 4 0 01-4-4v-4"/><circle cx="22" cy="22" r="7"/></svg>
        <h3>Scan</h3><p>Point the camera at your mug, the fridge, your backpack — it has to actually see it.</p>
        <div class="levels">Pick any object</div>
      </div>
      <a class="challenge" href="https://github.com/gretzke/open-alarm/issues">
        <svg class="icon" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 12v20M12 22h20"/></svg>
        <h3>Your idea</h3><p>Missing the challenge that would get you up? Open an issue — or build it yourself.</p>
        <div class="levels">Issues → Pull requests</div>
      </a>
    </div>
  </div>
</section>

<style>
  .sim-math { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14px; padding: 24px 18px; background: linear-gradient(to bottom, #3d1430, #8e1d22); }
  .sim-math .progress { font-size: 0.75rem; color: rgba(255,255,255,0.7); }
  .sim-math .expr { font-weight: 900; font-size: 2.2rem; font-variant-numeric: tabular-nums; }
  .sim-math .answer { width: 70%; padding: 8px 0; text-align: center; font-weight: 800; font-size: 1.2rem; border-radius: 14px; background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.25); }
  .sim-math .keypad { display: grid; grid-template-columns: repeat(3, 1fr); gap: 7px; width: 80%; margin-top: 6px; }
  .sim-math .key { padding: 7px 0; text-align: center; font-weight: 800; font-size: 0.85rem; border-radius: 12px; background: rgba(255,255,255,0.10); }
  .challenge-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; margin-top: 40px; }
  @media (max-width: 900px) { .challenge-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 580px) { .challenge-grid { grid-template-columns: 1fr; } }
  /* Community CTA card: dashed border = the empty slot you can fill */
  a.challenge { display: block; text-decoration: none; color: inherit; border-style: dashed; border-color: rgba(255,255,255,0.45); background: rgba(255,255,255,0.05); transition: background 0.2s, transform 0.15s; }
  a.challenge:hover { background: rgba(255,255,255,0.14); transform: translateY(-2px); }
  a.challenge:focus-visible { outline: 2px solid #fff; outline-offset: 3px; }
  .challenge { padding: 24px; border-radius: var(--r-card); background: rgba(255,255,255,0.10); border: 1px solid rgba(255,255,255,0.28); box-shadow: 0 10px 24px rgba(0,0,0,0.18); backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px); }
  .challenge .icon { width: 40px; height: 40px; margin-bottom: 12px; color: #fff; }
  .challenge h3 { font-weight: 900; font-size: 1.25rem; margin-bottom: 6px; }
  .challenge p { font-size: 0.9375rem; line-height: 1.55; color: rgba(255,255,255,0.82); }
  .challenge .levels { margin-top: 12px; font-size: 0.72rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.6); }
</style>
